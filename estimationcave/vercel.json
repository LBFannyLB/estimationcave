{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    },
    {
      "source": "/(.*).(webp|png|jpg|jpeg|gif|svg|ico|woff2|woff)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/article-cave-heritee-valeur.html",
      "destination": "/article-vins-parents-valeur-guide.html",
      "permanent": true
    },
    {
      "source": "/article-cave-heritee-valeur",
      "destination": "/article-vins-parents-valeur-guide",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/index_1.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/article-:slug([^.]+)",
      "destination": "/article-:slug.html",
      "permanent": true
    },
    {
      "source": "/:page(apropos|assureurs|blog|confidentialite|conseillers-patrimoine|estimation|faq|gestion|mentions-legales|merci|notaires|professionnels|vendre)",
      "destination": "/:page.html",
      "permanent": true
    }
  ]
}
